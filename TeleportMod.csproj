<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net6.0</TargetFramework>
    <AssemblyName>TeleportMod</AssemblyName>
    <RootNamespace>TeleportMod</RootNamespace>
    <Nullable>enable</Nullable>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <!-- Handles all SDV + SMAPI references and auto-deploys to the mods folder -->
